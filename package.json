    "@storybook/react-webpack5": "^8.6.18",
    "cypress": "^15.18.1",
    "eslint": "^8.57.1",
    "eslint-config-dicodingacademy": "^0.9.5",
    "eslint-plugin-react": "^7.37.5",
    "redux-mock-store": "^1.5.5",
    "redux-thunk": "^3.1.0",
    "start-server-and-test": "^3.0.11",
    "storybook": "^8.6.18"
